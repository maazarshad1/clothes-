{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "An order placed by a customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "postalCode": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["Pending", "Processing", "Shipped", "Delivered", "Cancelled"] },
        "date": { "type": "string" },
        "paymentMethod": { "type": "string", "enum": ["Card", "Cash on Delivery"] },
        "items": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "customerName", "email", "total", "status", "date"]
    },
    "Product": {
      "title": "Product",
      "description": "A product in the inventory",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "rating": { "type": "number" },
        "description": { "type": "string" },
        "colors": { "type": "array" }
      },
      "required": ["id", "name", "price", "category", "image"]
    },
    "Collection": {
      "title": "Collection",
      "description": "A curated group of products",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["name"]
    }
  },
  "firestore": {
    "orders": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "products": {
      "schema": "Product",
      "description": "Store products"
    },
    "collections": {
      "schema": "Collection",
      "description": "Curated product collections"
    }
  }
}
