rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'customerName', 'email', 'phoneNumber', 'address', 'city', 'postalCode', 'items', 'paymentMethod', 'total', 'status', 'date', 'createdAt'])
        && data.keys().size() == 13
        && data.id is string && data.id.size() <= 64
        && data.customerName is string && data.customerName.size() <= 200
        && data.email is string && data.email.size() <= 200
        && data.phoneNumber is string && data.phoneNumber.size() <= 50
        && data.address is string && data.address.size() <= 500
        && data.city is string && data.city.size() <= 100
        && data.postalCode is string && data.postalCode.size() <= 20
        && data.items is list && data.items.size() <= 100
        && data.paymentMethod in ['Card', 'Cash on Delivery']
        && data.total is number && data.total >= 0
        && data.status in ['Pending', 'Processing', 'Shipped', 'Delivered', 'Cancelled']
        && data.date is string
        && data.createdAt == request.time;
    }

    // Phase 4: Drafting the "Fortress" Rules
    match /test/connection {
      allow get: if true;
    }

    match /orders/{orderId} {
      // allow create for guests as requested/implied by checkout flow
      allow create: if isValidId(orderId) && isValidOrder(incoming());
      
      // Only authenticated admins should be able to read/list all orders if we had an admin role.
      // For now, these are accessible via the Firebase Console by the owner.
      // If we want the user to be able to track their order without login, 
      // we'd need a specific 'get' rule.
      allow get: if isValidId(orderId); 
    }
  }
}
